# .env.example - Example environment file for WorkSphere AI

# Environment
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite:///./work_sphere_ai.db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Security
SECRET_KEY=replace-with-a-secure-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=optiwork-uploads
AWS_S3_DOMAIN=s3.amazonaws.com

# SMTP Email (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@optiwork.ai

# Squad payment integration
# For production, use Squad production URL.
# For sandbox/testing, use the sandbox URL provided by Squad.
SQUAD_API_BASE_URL=https://api.squad.co
SQUAD_API_KEY=your-squad-api-key
SQUAD_API_SECRET=your-squad-api-secret
SQUAD_PAYOUT_PATH=/v1/transfers
SQUAD_REQUEST_TIMEOUT=30
SQUAD_RETRY_LIMIT=3
SQUAD_RETRY_BACKOFF_SECONDS=2

# Payroll
PAYROLL_DEFAULT_CURRENCY=USD
PAYROLL_TAX_PERCENTAGE=0.15
OVERTIME_MULTIPLIER=1.5

# Face Recognition
FACE_MATCH_THRESHOLD=0.6
FACE_LIVENESS_THRESHOLD=0.7
FACE_QUALITY_MIN_SCORE=0.7
USE_GPU=false
